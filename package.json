{
  "name": "agent-computer-use-mcp",
  "version": "0.0.1",
  "description": "A local MCP server for Gateway-managed computer use with cua-driver, OCR, and user-only desktop overlays.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astraclawteam/agent-computer-use-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/astraclawteam/agent-computer-use-mcp/issues"
  },
  "homepage": "https://github.com/astraclawteam/agent-computer-use-mcp#readme",
  "keywords": [
    "mcp",
    "computer-use",
    "cua",
    "desktop-automation",
    "agent"
  ],
  "bin": {
    "agent-computer-use-mcp": "src/computer-use-mcp-server.mjs"
  },
  "files": [
    "src",
    "scripts",
    "public",
    "gateway-overlay/*.csproj",

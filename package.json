    "gateway-overlay/*.html",
    "native-lab/*.csproj",
    "native-lab/*.cs",
    "ocr-sidecar/*.py",
    "ocr-sidecar/*.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",

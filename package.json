    "phase:1.4": "node src/phase-1-4-real-mcp-action.mjs",
    "phase:1.6": "node src/phase-1-6-installation.mjs",
    "phase:1.7": "node src/phase-1-7-standard-mcp-client.mjs",
    "phase:1.8": "node src/phase-1-8-standard-mcp-server.mjs",
